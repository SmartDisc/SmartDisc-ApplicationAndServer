<form class="admin-inline-form" method="post" action="{{ path('app_admin_disc_crud_delete', {'id': disc.id}) }}" onsubmit="return confirm('Are you sure you want to delete this disc? This cannot be undone.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ disc.id) }}">
    <button class="admin-btn admin-btn--danger" type="submit">Delete disc</button>
</form>
