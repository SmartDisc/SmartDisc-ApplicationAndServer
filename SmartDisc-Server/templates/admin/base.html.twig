{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
    <div class="admin-topbar">
        <nav class="admin-nav">
            <a class="admin-nav__signout" href="{{ path('app_admin_logout') }}">Sign out</a>
        </nav>
        <span class="admin-nav__user">{{ app.user.userIdentifier }}</span>
    </div>

    <div class="admin-main">
        {% for message in app.flashes('success') %}
            <div class="admin-flash admin-flash--success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="admin-flash admin-flash--error">{{ message }}</div>
        {% endfor %}

        {% block admin_body %}{% endblock %}
    </div>
{% endblock %}
