# Base URL of the smartdisc-server API, no trailing slash.
#
# Required for production/native builds: a Capacitor app's own origin
# (capacitor://localhost on iOS, https://localhost on Android) is never the
# API's origin, so a relative path won't reach it.
#
# In dev mode (`npm run dev`), this defaults to http://localhost:8083
# (the smartdisc-server's default docker compose HTTP_PORT) if left unset.
VITE_API_BASE_URL=http://localhost:8083
